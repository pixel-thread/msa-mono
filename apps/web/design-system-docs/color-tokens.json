{
  "system": "MFSA Connect Design System — Complete Color Token Reference",
  "version": "1.0.0",
  "framework": "Tailwind CSS v4 + CSS Custom Properties",
  "theme_engine": "Custom ThemeProvider (light/dark/auto via localStorage + prefers-color-scheme)",
  "dark_mode_selector": ".dark",

  "semantic_color_system": {
    "description": "All semantic tokens map to CSS custom properties. Values are stored as HEX. Tailwind v4 @theme directive creates utility classes from CSS variables.",
    "token_definition_location": "src/app/globals.css (custom properties) via @theme inline {} directive",
    "tailwind_mapping": "All --color-* variables in @theme directive map 1:1 with Tailwind utilities (e.g., bg-primary, text-muted-foreground, border-border)"
  },

  "core_semantic_tokens": {
    "primary": {
      "light_hex": "#0052ff",
      "dark_hex": "#0052ff",
      "css_var": "--primary",
      "tailwind": "primary",
      "oklch": "oklch(0.488 0.243 264.376)",
      "purpose": "Primary action color, brand identity, link color, active states"
    },
    "primary_foreground": {
      "light_hex": "#ffffff",
      "dark_hex": "#ffffff",
      "css_var": "--primary-foreground",
      "tailwind": "primary-foreground",
      "purpose": "Text on primary backgrounds"
    },
    "primary_active": {
      "light_hex": "#003ecc",

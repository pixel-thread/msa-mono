  "color_philosophy": {
    "contrast": "Moderate-to-high contrast ratio. Primary blue is vivid (#0052ff). Text colors use near-black (#0a0b0d) on white for maximum readability.",
    "saturation": "Selectively saturated. Primary is fully saturated blue. Destructive is vivid red. Chart colors are distinct. Neutrals are warm-cool balanced (slightly blue-tinted grays).",
    "dark_mode_strategy": "Inverted luminance. Light backgrounds become dark (#0a0b0d → #ffffff). Card surfaces get a subtle dark elevation (#16181c). Borders become darker (#dee1e6 → #2b2d31). Saturated colors (primary, destructive, semantic up/down) remain identical across modes. Chart-5 desaturates in dark mode.",
    "hover_interaction": "Opacity-based hover for primary (80% opacity). For destructive, uses transparent backgrounds (10% → 20% on hover).",
    "focus_indicators": "Ring color matches primary blue. Uses combo: focus-visible:border-ring + focus-visible:ring-2 + focus-visible:ring-ring/30 for accessibility."
  },


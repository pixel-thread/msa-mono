// ─────────────────────────────────────────────────────────────────────────────
// CONTRIBUTIONS
// ─────────────────────────────────────────────────────────────────────────────

model ContributionPeriod {
  id String @id @default(uuid())

  associationId String
  userId        String

  year  Int
  month Int

  expectedAmount Decimal @db.Decimal(10, 2)

  paidAmount Decimal @default(0) @db.Decimal(10, 2)

  dueAmount Decimal @db.Decimal(10, 2)

  status ContributionStatus @default(DUE)

  dueDate DateTime

  waivedAt     DateTime?
  waivedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  allocations  PaymentAllocation[]
  declarations ContributionDeclerations[]

  @@unique([userId, year, month])
  @@index([associationId])
  @@index([userId])
  @@index([status])
  @@map("contribution_periods")
}

model ContributionDeclerations {
  id                       String               @id @default(uuid())
  memberId                 String
  associationId            String
  declerationStartDate     DateTime
  declerationEndDate       DateTime
  montlyContributionAmount Decimal              @db.Decimal(10, 2)
  status                   DeclerationStatus    @default(PENDING)
  lastDeclarationDate      DateTime?
  reviewBy                 String?
  reviewAt                 DateTime?
  member                   User                 @relation(fields: [memberId], references: [id])
  association              Association          @relation(fields: [associationId], references: [id])
  periods                  ContributionPeriod[]

  @@map("contribution_declerations")
}

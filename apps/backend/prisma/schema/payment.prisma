// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS & LEDGER
// ─────────────────────────────────────────────────────────────────────────────
model PaymentReference{ 
  id String @id @default(uuid())
  type PaymentReferenceType?
  reference String?
  paidAt DateTime?
  remarks String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactionId String
  transaction PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("payment_references")
}

model PaymentTransaction {
  id String @id @default(uuid())

  associationId String
  userId        String?

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("INR")

  gateway PaymentGateway @default(RAZORPAY)

  status PaymentStatus @default(PENDING)

  method PaymentMethod?

  references PaymentReference[]

  notes String?

  // Razorpay
  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?
  razorpayRefundId  String?

  receiptUrl String?
  invoiceUrl String?

  paidAt   DateTime?
  failedAt DateTime?

  createdById  String?
  verifiedById String?

  paymentDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])

  allocations   PaymentAllocation[]
  ledgerEntries LedgerEntry[]

  @@index([associationId])
  @@index([userId])
  @@index([status])
  @@index([paymentDate])
  @@map("payment_transactions")
}

model PaymentAllocation {
  id String @id @default(uuid())

  paymentTransactionId String
  contributionPeriodId String

  allocatedAmount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  contributionPeriod ContributionPeriod @relation(fields: [contributionPeriodId], references: [id], onDelete: Cascade)

  @@index([paymentTransactionId])
  @@index([contributionPeriodId])
  @@map("payment_allocations")
}

model PaymentWebhookEvent {
  id String @id @default(uuid())

  eventId   String? @unique
  eventType String

  gateway PaymentGateway @default(RAZORPAY)

  payload Json

  signature String?

  processed Boolean @default(false)

  processedAt DateTime?

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([processed])
  @@map("payment_webhook_events")
}

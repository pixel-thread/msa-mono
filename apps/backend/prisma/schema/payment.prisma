// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS & LEDGER
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id String @id @default(uuid())

  associationId String
  userId        String

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("INR")

  gateway PaymentGateway @default(RAZORPAY)

  status PaymentStatus @default(PENDING)

  method PaymentMethod?

  referenceNumber String?
  receiptNumber   String?

  notes String?

  // Razorpay
  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?
  razorpayRefundId  String?

  receiptUrl String?
  invoiceUrl String?

  paidAt   DateTime?
  failedAt DateTime?

  createdById  String?
  verifiedById String?

  paymentDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  allocations   PaymentAllocation[]
  ledgerEntries LedgerEntry[]

  @@index([associationId])
  @@index([userId])
  @@index([status])
  @@index([paymentDate])
  @@map("payment_transactions")
}

model ContributionPeriod {
  id String @id @default(uuid())

  associationId String
  userId        String

  year  Int
  month Int

  expectedAmount Decimal @db.Decimal(10, 2)

  paidAmount Decimal @default(0) @db.Decimal(10, 2)

  dueAmount Decimal @db.Decimal(10, 2)

  status ContributionStatus @default(DUE)

  dueDate DateTime

  waivedAt     DateTime?
  waivedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  allocations PaymentAllocation[]

  @@unique([userId, year, month])
  @@index([associationId])
  @@index([userId])
  @@index([status])
  @@map("contribution_periods")
}

model PaymentAllocation {
  id String @id @default(uuid())

  paymentTransactionId String
  contributionPeriodId String

  allocatedAmount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  contributionPeriod ContributionPeriod @relation(fields: [contributionPeriodId], references: [id], onDelete: Cascade)

  @@index([paymentTransactionId])
  @@index([contributionPeriodId])
  @@map("payment_allocations")
}

model PaymentWebhookEvent {
  id String @id @default(uuid())

  eventId   String? @unique
  eventType String

  gateway PaymentGateway @default(RAZORPAY)

  payload Json

  signature String?

  processed Boolean @default(false)

  processedAt DateTime?

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([processed])
  @@map("payment_webhook_events")
}

model LedgerEntry {
  id                   String         @id @default(uuid())
  paymentTransactionId String?
  description          String
  approvalStatus       ApprovalStatus @default(PENDING)
  createdById          String
  approvedById         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])
  lines              LedgerLine[]

  @@index([paymentTransactionId])
  @@map("ledger_entries")
}

model LedgerLine {
  id            String   @id @default(uuid())
  ledgerEntryId String
  associationId String
  accountId     String // ID of the chart of accounts
  isDebit       Boolean // true for debit, false for credit
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
  @@map("ledger_lines")
}

model Account {
  id            String   @id @default(uuid())
  associationId String
  code          String
  name          String
  type          String
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  association Association  @relation(fields: [associationId], references: [id], onDelete: Cascade)
  lines       LedgerLine[]

  @@index([associationId])
  @@index([code])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT PROVIDERS (Multi-Tenant)
// ─────────────────────────────────────────────────────────────────────────────

model PaymentProvider {
  id                     String              @id @default(uuid())
  associationId          String
  provider               PaymentProviderType
  keyId                  String
  encryptedKeySecret     String
  encryptedWebhookSecret String?
  isActive               Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  @@index([associationId])
  @@map("payment_providers")
}

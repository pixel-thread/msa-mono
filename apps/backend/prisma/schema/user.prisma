// ─────────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                       String        @id @default(uuid())
  associationId            String
  email                    String        @unique
  name                     String
  firstName                String
  middleName               String?
  lastName                 String?
  mobile                   String?
  designation              String?
  role                     UserRole[]
  status                   UserStatus    @default(ACTIVE)
  dateOfJoiningGovt        DateTime?
  dateOfJoiningAssociation DateTime?
  dateOfRetirement         DateTime?
  dob                      DateTime?
  membershipNumber         String?
  overallConsentStatus     ConsentStatus @default(GRANTED)
  dataRetentionUntil       DateTime      @default(dbgenerated("(NOW() + INTERVAL '7 years')"))
  failedLoginAttempts      Int           @default(0)
  lockedUntil              DateTime?
  imageUrl                 String?
  password                 String?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  mfaEnabled               Boolean       @default(false)
  deletedAt                DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  payments              PaymentTransaction[]
  contributionPeriods   ContributionPeriod[]
  auditLogs             AuditLog[]            @relation("ActorLogs")
  meetingsCreated       Meeting[]             @relation("CreatedMeetings")
  meetingAttendances    MeetingAttendee[] // ★ Meetings this user is assigned to
  refreshTokens         RefreshToken[]
  verificationCodes     VerificationCode[]
  pushTokens            PushToken[]
  authoredAnnouncements Announcement[]        @relation("AuthoredAnnouncements")
  announcementReads     AnnouncementRead[]
  dsarTickets           DsarTicket[]          @relation("MemberTickets")
  assignedDsarTickets   DsarTicket[]          @relation("AssignedTickets")
  consentReceipts       ConsentReceipt[]
  trainingCompletions   TrainingCompletion[]
  complaints            Complaint[]
  trainingAssignments   TrainingAssignment[]
  trainingCertificates  TrainingCertificate[]
  memberTypeId          String?
  memberType            MemberType?           @relation(fields: [memberTypeId], references: [id])
  declerations          Declarations[]
  reviewedDeclerations  Declarations[]        @relation("reviewedBy")

  @@unique([associationId, email])
  @@unique([associationId, membershipNumber])
  @@index([associationId])
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([dataRetentionUntil])
  @@index([passwordResetToken])
  @@map("users")
}

model MembershipApplication {
  id              String   @id @default(uuid())
  email           String
  phone           String
  associationSlug String
  firstName       String?
  middleName      String?
  lastName        String?
  dateOfBirth     DateTime
  age             Int
  gender          String?
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?

  status          ApplicationStatus @default(PENDING)
  rejectionReason String? // Helpful if an admin denies their sign-up
  reviewedAt      DateTime?
  reviewedBy      String? // ID of the admin who approved/rejected them

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, associationSlug])
  @@unique([phone, associationSlug])
  @@index([email])
  @@index([phone])
  @@index([associationSlug])
  @@index([status]) // Added an index since your admins will filter by status often
  @@map("membership_applications")
}

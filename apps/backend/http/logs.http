@NEXT_PUBLIC_API_BASE_URL = http://localhost:4000/api/v1
@TOKEN = REPLACE_WITH_TOKEN_FROM_AUTH_HTTP
@userId = 7e534916-ffcc-467a-811a-b2544840777d

###
# @name getLogs
GET {{NEXT_PUBLIC_API_BASE_URL}}/logs?page=1&limit=20
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name getLogsFilteredByLevel
GET {{NEXT_PUBLIC_API_BASE_URL}}/logs?level=error&page=1&limit=10
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name searchLogs
GET {{NEXT_PUBLIC_API_BASE_URL}}/logs?search=payment&page=1&limit=20
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name getLogsDateRange
GET {{NEXT_PUBLIC_API_BASE_URL}}/logs?startDate=2026-05-01T00:00:00Z&endDate=2026-05-17T23:59:59Z&page=1&limit=50
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name getFrontendLogs
GET {{NEXT_PUBLIC_API_BASE_URL}}/logs?isBackend=false&page=1&limit=20&startDate=2026-2-1&endDate=2026-5-20
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name ingestLog
POST {{NEXT_PUBLIC_API_BASE_URL}}/logs
Content-Type: application/json

{
  "level": "error",
  "message": "Something went wrong",
  "context": {
    "userId": "{{userId}}",
    "action": "payment.process"
  }
}

###
# @name batchIngestLogs
POST {{NEXT_PUBLIC_API_BASE_URL}}/logs/batch
Content-Type: application/json

{
  "logs": [
    {
      "level": "error",
      "message": "Payment failed",
      "context": { "userId": "{{userId}}" }
    },
    {
      "level": "warn",
      "message": "Slow query detected",
      "context": { "duration": 2500 }
    },
    {
      "level": "info",
      "message": "User logged in",
      "context": { "userId": "{{userId}}" }
    }
  ]
}

@notificationId = REPLACE_WITH_NOTIFICATION_ID

###
# @name registerPushToken
POST {{NEXT_PUBLIC_API_BASE_URL}}/notifications/register
Content-Type: application/json

{
  "token": "exponent-push-token-here"
}

###
# @name linkTokenToUser
POST {{NEXT_PUBLIC_API_BASE_URL}}/notifications/link
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "token": "exponent-push-token-here"
}

###
# @name updateNotificationStatus
PATCH {{NEXT_PUBLIC_API_BASE_URL}}/notifications/{{notificationId}}/status
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "read": true
}

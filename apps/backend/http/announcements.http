@announcementId = 6fd37ef7-007b-4a2f-8a04-0932e94b4f2a

###
# @name listAnnouncements
GET {{NEXT_PUBLIC_API_BASE_URL}}/announcement?page=1&limit=10
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name listAnnouncementsWithFilters
GET {{NEXT_PUBLIC_API_BASE_URL}}/announcements?status=PUBLISHED&priority=HIGH&page=1&limit=10
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name searchAnnouncements
GET {{NEXT_PUBLIC_API_BASE_URL}}/announcements?search=important&page=1
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name createAnnouncementDraft
POST {{NEXT_PUBLIC_API_BASE_URL}}/announcements
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Important Update on Membership",
  "summary": "New membership benefits starting next month",
  "content": "We are excited to announce new benefits for all members...",
  "status": "DRAFT",
  "priority": "NORMAL",
  "isPinned": false
}

###
# @name createAndPublishAnnouncement
POST {{NEXT_PUBLIC_API_BASE_URL}}/announcements
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Emergency Meeting Notice",
  "summary": "Urgent: All members please note",
  "content": "There will be an emergency meeting on June 20th...",
  "status": "PUBLISHED",
  "priority": "URGENT",
  "targetRoles": ["PRESIDENT", "SECRETARY", "FINANCE"],
  "isPinned": true
}

###
# @name createScheduledAnnouncement
POST {{NEXT_PUBLIC_API_BASE_URL}}/announcements
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Upcoming Annual General Meeting",
  "summary": "AGM scheduled for July 15th",
  "content": "The Annual General Meeting will be held on July 15th at 10:00 AM...",
  "status": "SCHEDULED",
  "priority": "HIGH",
  "publishedAt": "2026-06-01T00:00:00Z",
  "targetRoles": []
}

###
# @name getAnnouncementById
GET {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name updateAnnouncement
PUT {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Updated Announcement Title",
  "summary": "Updated summary text",
  "priority": "HIGH",
  "isPinned": true
}

###
# @name deleteAnnouncement
DELETE {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name publishAnnouncement
PATCH {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "action": "publish"
}

###
# @name archiveAnnouncement
PATCH {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "action": "archive"
}

###
# @name unpublishAnnouncement
PATCH {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "action": "unpublish"
}

###
# @name uploadAnnouncementImage
POST {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}/upload
Content-Type: multipart/form-data; boundary=ann
Authorization: Bearer {{TOKEN}}

--ann
Content-Disposition: form-data; name="file"; filename="image.png"
Content-Type: image/png

< ./test-data/test-supplement.png
--ann--

###
# @name markAnnouncementAsRead
POST {{NEXT_PUBLIC_API_BASE_URL}}/announcements/{{announcementId}}/read
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

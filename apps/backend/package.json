{
  "name": "mfsa-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "build": "tsc && tsc-alias",
    "build:api": "tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "check": "prettier --check \"src/**/*.{ts,js,json}\" && eslint src/ --ext .ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --runInBand"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.106.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.2.1",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "jose": "^6.0.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "razorpay": "^2.9.6",
    "resend": "^6.12.3",
    "ssh2-sftp-client": "^12.1.1",
    "tsconfig-paths": "^4.2.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=22"
  }
}
